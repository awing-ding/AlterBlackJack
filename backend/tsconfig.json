{
  "compilerOptions": {
    "target": "es2024",
    "module": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "@database/*": ["./database/*"],
      "@routes/*": ["./routes/*"],
    }
  }
}
