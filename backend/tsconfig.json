{
  "compilerOptions": {
    "baseUrl": "./",
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./*"],
      "@database/*": ["./database/*"],
      "@routes/*": ["./routes/*"]
    },
    "allowSyntheticDefaultImports": true
  }
}
